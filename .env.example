# Non-secret runtime settings only. Every MCP tool receives workspace_id explicitly;
# there is no default workspace or static allowlist.
TAPD_WEB_BASE_URL=https://www.tapd.cn
TAPD_MAX_REQUESTS_PER_MINUTE=60
TAPD_REQUEST_TIMEOUT_MS=20000

# By default, the package stores its session in the per-user data directory:
# macOS ~/Library/Application Support/tapd-mcp; Windows %APPDATA%\tapd-mcp;
# Linux $XDG_STATE_HOME/tapd-mcp (or ~/.local/state/tapd-mcp).
# Override the whole directory or individual paths only for managed deployments.
# TAPD_DATA_DIR=/absolute/path/to/tapd-mcp-data
# TAPD_USER_PROMPT_PATH=/absolute/path/to/tapd-mcp-data/prompt.md
# TAPD_SESSION_STORE_PATH=/absolute/path/to/tapd-mcp-data/session.json
# TAPD_CHROME_USER_DATA_DIR=/absolute/path/to/chrome-user-data

# Never put Cookie, dsc_token, query_token, Open API credentials, or recovery
# tokens in this file. tapd_refresh_session acquires the Web session from an
# already logged-in Chrome TAPD tab and writes it only to TAPD_SESSION_STORE_PATH.
