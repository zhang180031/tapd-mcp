{
  "name": "@zhang180031/tapd-mcp",
  "version": "0.5.0",
  "description": "A session-backed MCP server for TAPD Web story and bug APIs.",
  "type": "module",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tapd",
    "tencent",
    "agile",
    "bug-tracker"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhang180031/tapd-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/zhang180031/tapd-mcp/issues"
  },
  "homepage": "https://github.com/zhang180031/tapd-mcp#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist/src",
    "README.md",
    ".env.example",
    "codex.mcp.config.example.toml"
  ],
  "bin": {
    "tapd-mcp": "dist/src/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npm run build && node --test dist/test/*.test.js",
    "test:integration": "npm run build && node --test dist/test/*.integration.js",
    "test:e2e:tapd": "npm run build && node --test dist/test/*.e2e.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
